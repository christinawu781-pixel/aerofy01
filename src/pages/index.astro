<!-- ═══════════════════════════════════════════
     GSAP + SCROLLTRIGGER SCRIPT
     ═══════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  /* ──────────────────────────────────────────
     0. PRELOAD FRAMES + LOADER
     ────────────────────────────────────────── */
  const FRAME_COUNT = 120;
  const frames: HTMLImageElement[] = [];
  let loaded = 0;
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const loaderBar = document.getElementById('loader-bar') as HTMLElement;
  const loaderPct = document.getElementById('loader-pct') as HTMLElement;
  const loaderEl  = document.getElementById('loader') as HTMLElement;

  function resizeCanvas() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);

  function drawFrame(idx: number) {
    if (!frames[idx]) return;
    const img = frames[idx];
    const scale = Math.max(canvas.width / img.width, canvas.height / img.height);
    const w = img.width * scale;
    const h = img.height * scale;
    const x = (canvas.width - w) / 2;
    const y = (canvas.height - h) / 2;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(img, x, y, w, h);
  }

  const frameState = { current: 0 };

  function preloadFrames(): Promise<void> {
    return new Promise((resolve) => {
      for (let i = 1; i <= FRAME_COUNT; i++) {
        const img = new Image();
        img.src = `/frames/frame_${String(i).padStart(4, '0')}.webp`;
        img.onload = () => {
          loaded++;
          const pct = Math.round((loaded / FRAME_COUNT) * 100);
          loaderBar.style.width = pct + '%';
          loaderPct.textContent = pct + '%';
          if (loaded === FRAME_COUNT) resolve();
        };
        img.onerror = () => {
          loaded++;
          if (loaded === FRAME_COUNT) resolve();
        };
        frames[i - 1] = img;
      }
    });
  }

  async function init() {
    await preloadFrames();
    drawFrame(0);

    // Hide loader
    loaderEl.classList.add('done');
    setTimeout(() => { loaderEl.style.display = 'none'; }, 700);

    // Start all animations
    setupHero();
    setupNav();
    setupScrollAnims();
    setupFeatureGlow();
    setupFAQ();
  }

  /* ──────────────────────────────────────────
     1. HERO — Master ScrollTrigger Timeline
     ────────────────────────────────────────── */
  function setupHero() {
    // Entrance animations (on load, not scroll)
    const enterTl = gsap.timeline({ delay: 0.5 });
    enterTl
      .to('#hero-badge', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' })
      .to('#hero-line-1', { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out' }, '-=0.5')
      .to('#hero-line-2', { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out' }, '-=0.6')
      .to('#hero-sub', { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.5')
      .to('#hero-scroll-hint', { opacity: 1, duration: 0.6 }, '-=0.3');

    // Master scroll timeline
    const heroTl = gsap.timeline({
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom bottom',
        scrub: 0.5,
        pin: '#hero-pin',
        anticipatePin: 1,
      }
    });

    // Phase 1 (0–0.25): Frame animation + text exit
    heroTl
      // Frame scrub
      .to(frameState, {
        current: FRAME_COUNT - 1,
        duration: 1,
        ease: 'none',
        onUpdate: () => drawFrame(Math.round(frameState.current)),
      }, 0)
      // Text exits — each line flies differently
      .to('#hero-badge', { opacity: 0, y: -40, duration: 0.15, ease: 'power2.in' }, 0.02)
      .to('#hero-line-1', { opacity: 0, x: -200, duration: 0.2, ease: 'power2.in' }, 0.05)
      .to('#hero-line-2', { opacity: 0, scale: 2.5, duration: 0.2, ease: 'power2.in' }, 0.08)
      .to('#hero-sub', { opacity: 0, x: 200, duration: 0.15, ease: 'power2.in' }, 0.06)
      .to('#hero-scroll-hint', { opacity: 0, duration: 0.08 }, 0)

      // Phase 2 (0.35–0.6): Mid tagline
      .fromTo('#hero-mid-tagline', { opacity: 0 }, { opacity: 1, duration: 0.12, ease: 'power2.out' }, 0.35)
      .to('#hero-mid-tagline', { opacity: 0, duration: 0.1, ease: 'power2.in' }, 0.55)

      // Phase 3 (0.7–1.0): End specs
      .fromTo('#hero-end-left', { opacity: 0, x: -80 }, { opacity: 1, x: 0, duration: 0.15, ease: 'power3.out' }, 0.72)
      .fromTo('#hero-end-right', { opacity: 0, x: 80 }, { opacity: 1, x: 0, duration: 0.15, ease: 'power3.out' }, 0.75);
  }

  /* ──────────────────────────────────────────
     2. NAV — Hide/Show on scroll direction
     ────────────────────────────────────────── */
  function setupNav() {
    const nav = document.getElementById('nav')!;
    let lastScroll = 0;

    ScrollTrigger.create({
      start: 0,
      end: 'max',
      onUpdate: (self) => {
        const scrollY = self.scroll();
        // Add scrolled class for glass effect
        nav.classList.toggle('scrolled', scrollY > 80);
        // Hide on scroll down, show on scroll up
        if (scrollY > lastScroll && scrollY > 200) {
          nav.classList.add('hidden');
        } else {
          nav.classList.remove('hidden');
        }
        lastScroll = scrollY;
      }
    });
  }

  /* ──────────────────────────────────────────
     3. SCROLL-TRIGGERED SECTION ANIMATIONS
     ────────────────────────────────────────── */
  function setupScrollAnims() {
    // Generic anim-up / anim-left / anim-right / anim-scale
    document.querySelectorAll('.anim-up').forEach((el, i) => {
      gsap.to(el, {
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          toggleActions: 'play none none none',
        },
        opacity: 1, y: 0,
        duration: 0.9,
        delay: (el.closest('.features-grid, .reviews-grid, .smart-grid, .support-cards, .stats-inner, .dual-grid, .specs-table'))
          ? (Array.from(el.parentElement!.children).indexOf(el as Element) * 0.08) : 0,
        ease: 'power3.out',
      });
    });

    document.querySelectorAll('.anim-left').forEach((el, i) => {
      gsap.to(el, {
        scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
        opacity: 1, x: 0, duration: 0.9,
        delay: (Array.from(el.parentElement!.children).indexOf(el as Element) * 0.1),
        ease: 'power3.out',
      });
    });

    document.querySelectorAll('.anim-right').forEach((el) => {
      gsap.to(el, {
        scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
        opacity: 1, x: 0, duration: 0.9, ease: 'power3.out',
      });
    });

    document.querySelectorAll('.anim-scale').forEach((el) => {
      gsap.to(el, {
        scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
        opacity: 1, scale: 1, duration: 1.2, ease: 'elastic.out(1,0.6)',
      });
    });

    // Feature card progress bars
    document.querySelectorAll('.feature-card').forEach((card) => {
      const bar = card.querySelector('.feature-bar-fill') as HTMLElement;
      const target = (card as HTMLElement).dataset.bar || '80';
      ScrollTrigger.create({
        trigger: card,
        start: 'top 80%',
        onEnter: () => { bar.style.width = target + '%'; }
      });
    });

    // Review rating bars
    document.querySelectorAll('.review-bar-fill[data-width]').forEach((bar) => {
      const w = (bar as HTMLElement).dataset.width || '0';
      ScrollTrigger.create({
        trigger: bar,
        start: 'top 90%',
        onEnter: () => {
          gsap.to(bar, { width: w + '%', duration: 1.2, ease: 'power3.out' });
        }
      });
    });

    // Counting numbers
    document.querySelectorAll('[data-count]').forEach((el) => {
      const target = parseFloat((el as HTMLElement).dataset.count || '0');
      const isDecimal = String(target).includes('.');
      ScrollTrigger.create({
        trigger: el,
        start: 'top 85%',
        onEnter: () => {
          gsap.to({ val: 0 }, {
            val: target,
            duration: 2,
            ease: 'power2.out',
            onUpdate: function() {
              (el as HTMLElement).textContent = isDecimal
                ? this.targets()[0].val.toFixed(2)
                : Math.round(this.targets()[0].val).toString();
            }
          });
        }
      });
    });

    // Scramble text reveal
    const scrambleEl = document.getElementById('scramble-text');
    if (scrambleEl) {
      const original = scrambleEl.innerHTML;
      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%';
      ScrollTrigger.create({
        trigger: scrambleEl,
        start: 'top 80%',
        onEnter: () => {
          // Extract text nodes
          const textContent = scrambleEl.textContent || '';
          let iterations = 0;
          const maxIterations = textContent.length;
          const interval = setInterval(() => {
            // Build scrambled version
            scrambleEl.innerHTML = original.replace(/[A-Za-z]/g, (char, offset) => {
              // Find actual position in text
              if (offset < iterations * 2) return char;
              return chars[Math.floor(Math.random() * chars.length)];
            });
            iterations++;
            if (iterations > maxIterations / 1.5) {
              scrambleEl.innerHTML = original;
              clearInterval(interval);
            }
          }, 30);
        }
      });
    }

    // Warranty badge ring animation
    const rings = document.querySelectorAll('.warranty-ring');
    rings.forEach((ring, i) => {
      ScrollTrigger.create({
        trigger: '#warranty-badge',
        start: 'top 80%',
        onEnter: () => {
          gsap.fromTo(ring,
            { scale: 0.5, opacity: 0 },
            { scale: 1, opacity: 1, duration: 1, delay: i * 0.2, ease: 'elastic.out(1,0.5)' }
          );
        }
      });
    });
  }

  /* ──────────────────────────────────────────
     4. MOUSE-FOLLOW GLOW on feature cards
     ────────────────────────────────────────── */
  function setupFeatureGlow() {
    document.querySelectorAll('.feature-card').forEach((card) => {
      const glow = card.querySelector('.card-glow') as HTMLElement;
      if (!glow) return;
      card.addEventListener('mousemove', (e: Event) => {
        const me = e as MouseEvent;
        const rect = (card as HTMLElement).getBoundingClientRect();
        glow.style.left = (me.clientX - rect.left) + 'px';
        glow.style.top = (me.clientY - rect.top) + 'px';
      });
    });
  }

  /* ──────────────────────────────────────────
     5. FAQ ACCORDION
     ────────────────────────────────────────── */
  function setupFAQ() {
    document.querySelectorAll('.faq-question').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.parentElement!;
        const wasOpen = item.classList.contains('open');
        // Close all
        document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
        // Toggle
        if (!wasOpen) item.classList.add('open');
      });
    });
  }

  /* ──────────────────────────────────────────
     BOOT
     ────────────────────────────────────────── */
  init();
</script>

</Layout>
